BOATRACE_APP_ROOT=/workspace/boat
BOATRACE_PYTHON=/workspace/boat/.venv/bin/python
BOATRACE_RAW_DIR=/workspace/boat/data/raw
BOATRACE_COLLECTOR_LOCK=/workspace/boat/run/postgresql-collector.lock
BOATRACE_POSTGRES_DSN='host=127.0.0.1 port=5432 dbname=boatrace user=boatrace_app'
BOATRACE_PGPASSFILE=/workspace/postgresql/conf/databases/boatrace.pgpass
