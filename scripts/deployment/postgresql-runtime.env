BOATRACE_APP_ROOT=/workspace/boat
BOATRACE_PYTHON=/workspace/boat/.venv/bin/python
BOATRACE_RAW_DIR=/workspace/shared-services/boatrace-runtime/data/raw
BOATRACE_COLLECTOR_LOG=/workspace/shared-services/boatrace-runtime/log/collector.log
BOATRACE_COLLECTOR_LOCK=/workspace/shared-services/boatrace-runtime/run/collector.lock
BOATRACE_RESTART_DELAY=10
BOATRACE_POSTGRES_DSN='host=127.0.0.1 port=5432 dbname=boatrace user=boatrace_app'
BOATRACE_PGPASSFILE=/workspace/shared-services/postgresql/conf/databases/boatrace.pgpass
